<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="ITHSystems.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
     xmlns:resources="clr-namespace:ITHSystems.Resx"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:login="clr-namespace:ITHSystems.Views.Login"
    xmlns:views="clr-namespace:ITHSystems.Views.Home"
    xmlns:camera="clr-namespace:ITHSystems.Controls"
     xmlns:controls="clr-namespace:ITHSystems.Controls"
xmlns:icon="clr-namespace:ITHSystems.UsesCases.IconFonts"
    xmlns:home="clr-namespace:ITHSystems.Views.Home"
    xmlns:android="clr-namespace:CommunityToolkit.Maui.PlatformConfiguration.AndroidSpecific;assembly=CommunityToolkit.Maui"
               android:NavigationBar.Color="{StaticResource Primary}"
    FlyoutBehavior="Flyout"
    Shell.NavBarIsVisible="False"
    BackgroundColor="{StaticResource bgColorPage}"
    Title="iThot System">
    
    <Shell.Behaviors>
        <toolkit:StatusBarBehavior StatusBarColor="#9C1A15"
                                   StatusBarStyle="DarkContent"
                                   ApplyOn="OnPageNavigatedTo"/>

    </Shell.Behaviors>


    <!--<ShellContent Title="{Static resources:IBSResources.Logout}"
                  ContentTemplate="{DataTemplate login:LoginPage}"
                  Route="LoginPage"
                  Shell.TabBarIsVisible="False"
                  />

    <ShellContent Title="cameraPage"
                  ContentTemplate="{DataTemplate camera:CameraControlPage}"
                  Route="CameraControlPage"
                   Shell.TabBarIsVisible="False"
                  />-->

   
    <Shell.FlyoutHeader>
        <Grid
            BackgroundColor="{StaticResource bgColorPage}"
            Padding="0">
            
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <BoxView HeightRequest="170"
                     VerticalOptions="Start"
                     BackgroundColor="Transparent"> 
                <BoxView.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="{StaticResource Primary}" Offset="0.0" />
                        <GradientStop Color="{StaticResource bgColorPage}" Offset="1.0" />
                    </LinearGradientBrush>
                </BoxView.Background>
            </BoxView>

            <Border VerticalOptions="Center"
                    HorizontalOptions="Center"
                    Stroke="Transparent"
                    Margin="-10,0,0,0"
                    >
                <Image Source="logo_ibs.png"
                       HeightRequest="160"
                       WidthRequest="160"
                       />
            </Border>
            <Label
                Text="iThot System"
                FontSize="22"
                FontAttributes="Bold"
                VerticalOptions="Start"
                HorizontalTextAlignment="Center"
                TextColor="{StaticResource White}"
                FontFamily="{Static icon:FontFamilyIcons.FluentUI}"
                    
                />

        </Grid>
    </Shell.FlyoutHeader>

 
        <ShellContent
                    Title="Login"
                    ContentTemplate="{DataTemplate login:LoginPage}"
                    Route="LoginPage"
                    Shell.FlyoutItemIsVisible="False"
                    Shell.TabBarIsVisible="False" />



    <FlyoutItem>
        
        <ShellContent Title="Home"
                      ContentTemplate="{DataTemplate home:HomePage}"
                      Route="HomePage"/>
        
        <ShellContent Title="Cerrar Session"
                   ContentTemplate="{DataTemplate login:LoginPage}"
                   Route="LoginPage"/>
    </FlyoutItem>
   
    
    <Shell.FlyoutFooter>
        <Grid BackgroundColor="{StaticResource bgColorPage}">

            <Label Text="iThot System v1.0.0.0"
                   FontSize="10"
                   Padding="6,2"
                   FontAttributes="Bold"
                   FontFamily="{Static icon:FontFamilyIcons.FluentUI}"
                   TextColor="{StaticResource Gray600}"
                   />
        </Grid>
    </Shell.FlyoutFooter>


   




</Shell>
