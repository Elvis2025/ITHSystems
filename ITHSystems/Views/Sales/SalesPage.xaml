<?xml version="1.0" encoding="utf-8" ?>
<views:BaseContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                       xmlns:views="clr-namespace:ITHSystems.Views"
                       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                       x:Class="ITHSystems.Views.Sales.SalesPage"
                       xmlns:vm="clr-namespace:ITHSystems.Views.Sales"
                       xmlns:resources="clr-namespace:ITHSystems.Resx"
                       xmlns:icon="clr-namespace:ITHSystems.UsesCases.IconFonts"
                       xmlns:controls="clr-namespace:ITHSystems.Controls"
                       xmlns:dto="clr-namespace:ITHSystems.DTOs"
                       BackgroundColor="{StaticResource bgColorPage}"
                       HideSoftInputOnTapped="True"
                       x:TypeArguments="vm:SalesViewModel">

    <Grid RowDefinitions="Auto,*,Auto"
          RowSpacing="0">

        <Grid Grid.Row="0">
            <controls:GradientHeader
                Title="Productos"
                BackButtonCommand="{Binding GoBackCommand}" />
            <Label Text="{Static icon:IconFont.CartPlus}"
                     FontFamily="{Static icon:FontFamilyIcons.FaSolid}"
                     FontSize="22"
                     TextColor="{StaticResource bgColorPage}"
                     VerticalTextAlignment="Center" 
                   HorizontalOptions="End"
                    Padding="5"
                   Margin="0,-70,42,0"
                    >
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding FindProductsCommand}"/>
                </Label.GestureRecognizers>
            </Label>
            <controls:BarcodeScannerView BarcodeDetectedCommand="{Binding SearchProductByBarcodeCommand}"
                  LastDetectedBarcode="{Binding LastScannedBarcode}"
                  IsScanning="True" 
                                        Margin="0,0,0,90"
                                         IsVisible="True"
                                         ZIndex="2"
                                         />
            <Border Padding="5,1"
                    VerticalOptions="Start"
                    HorizontalOptions="End"
                    BackgroundColor="Green"
                    StrokeShape="RoundRectangle 100"
                    ZIndex="1"
                    Margin="0,6,34,0"
                    Stroke="Transparent"
                    >
                <Label Text="0"
                       TextColor="{StaticResource bgColorPage}"
                       FontSize="10"
                       FontAttributes="Bold"
                       />
            </Border>
            <Border Margin="16,46,16,24"
                    Padding="0"
                    BackgroundColor="{StaticResource White}"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 24"
                    HeightRequest="46"
                    VerticalOptions="End">

                <Grid ColumnDefinitions="*,Auto,Auto"
                      ColumnSpacing="10"
                      Padding="0">

                    <Entry Grid.Column="0"
                           Placeholder="Buscar producto..."
                           PlaceholderColor="{StaticResource Gray400}"
                           Text="{Binding FiterText}"
                           TextColor="{StaticResource Gray900}"
                           BackgroundColor="Transparent"
                           ClearButtonVisibility="WhileEditing"
                           FontSize="15"
                           Margin="18,0,0,0"
                           HeightRequest="70"
                           VerticalOptions="Center"
                           
                           ReturnType="Search">
                        <Entry.Behaviors>
                        </Entry.Behaviors>
                        <Entry.ReturnCommand>
                            <Binding Path="FindProductsCommand" />
                        </Entry.ReturnCommand>
                    </Entry>

                    <HorizontalStackLayout Spacing="8" Grid.Column="1" Margin="0,0,14,0">
                        <Label Text="{Static icon:IconFont.MagnifyingGlass}"
                                FontFamily="{Static icon:FontFamilyIcons.FaSolid}"
                                FontSize="22"
                                TextColor="{StaticResource Primary}"
                                VerticalTextAlignment="Center" 
                               Padding="5"
                               >
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding FindProductsCommand}"/>
                            </Label.GestureRecognizers>
                        </Label>
                        <Label Text="{Static icon:IconFont.Barcode}"
                               FontFamily="{Static icon:FontFamilyIcons.FaSolid}"
                               VerticalTextAlignment="Center" 
                               TextColor="{StaticResource Gray900}"
                                FontSize="26"
                               />
                    </HorizontalStackLayout>


                </Grid>
            </Border>
        </Grid>

        <CollectionView Grid.Row="1"
                        Margin="16,0,16,10"
                        ItemsSource="{Binding Products}"
                        SelectionMode="None"
                        VerticalScrollBarVisibility="Never"
                        BackgroundColor="Transparent">

            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="14" />
            </CollectionView.ItemsLayout>

            <CollectionView.EmptyView>
                <VerticalStackLayout Padding="20,40"
                                     Spacing="12"
                                     HorizontalOptions="Center"
                                     VerticalOptions="Center">
                    <Border WidthRequest="72"
                            HeightRequest="72"
                            BackgroundColor="#F4F6F8"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 24">
                        <Label Text="{Static icon:IconFont.BoxOpen}"
                               FontFamily="{Static icon:FontFamilyIcons.FaSolid}"
                               FontSize="30"
                               TextColor="{StaticResource Gray400}"
                               HorizontalTextAlignment="Center"
                               VerticalTextAlignment="Center" />
                    </Border>

                    <Label Text="No se encontraron productos"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="{StaticResource Gray900}"
                           HorizontalTextAlignment="Center" />

                    <Label Text="Prueba con otra descripción o código de barra."
                           FontSize="13"
                           TextColor="{StaticResource Gray500}"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="dto:ProductDto">
                    <Border BackgroundColor="{StaticResource White}"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 24"
                            Padding="12">

                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OpenProductDetailsCommand}"
                                                  CommandParameter="{Binding .}" />
                        </Border.GestureRecognizers>

                        <Grid ColumnDefinitions="96,*,Auto"
                              ColumnSpacing="14">
                                
                            <!-- Product image -->
                            <Border Grid.Column="0"
                                    WidthRequest="96"
                                    HeightRequest="96"
                                    BackgroundColor="#F7F8FA"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 20">
                                <Grid>
                                    <Image Source="{Binding ImageSource}"
                                           Aspect="AspectFill" />
                                    
                                </Grid>
                            </Border>
                            <Grid Grid.Column="1" RowDefinitions="*,Auto">
                                
                    
                                <HorizontalStackLayout Grid.Column="1"
                                                       Grid.Row="0"
                                                         Spacing="6"
                                                       HorizontalOptions="End"
                                                         VerticalOptions="Center">          

                                    <Label Text="{Binding Description}"
                                           FontSize="12"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource Gray900}"
                                           LineBreakMode="TailTruncation"
                                           MaxLines="2" />




                                </HorizontalStackLayout>


                                <!-- Price + CTA -->
                                <VerticalStackLayout Grid.Column="2"
                                                     Grid.Row="1"
                                                     Spacing="10"
                                                     VerticalOptions="Center"
                                                     HorizontalOptions="End">

                                    <VerticalStackLayout Spacing="2">
                                        <Label Text="Precio"
                                               FontSize="11"
                                               TextColor="{StaticResource Gray400}"
                                               HorizontalTextAlignment="End" />

                                        <Label Text="{Binding Price, StringFormat='RD$ {0:N2}'}"
                                               FontSize="20"
                                               FontAttributes="Bold"
                                               TextColor="{StaticResource Primary}"
                                               HorizontalTextAlignment="End" />
                                    </VerticalStackLayout>

                                    <Border BackgroundColor="{StaticResource Primary}"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 16"
                                            Padding="12,8"
                                            HorizontalOptions="End">
                                        <HorizontalStackLayout Spacing="6">
                                            <Label Text="{Static icon:IconFont.CartPlus}"
                                                   FontFamily="{Static icon:FontFamilyIcons.FaSolid}"
                                                   FontSize="14"
                                                   TextColor="{StaticResource White}" />
                                            <Label Text="Agregar"
                                                   FontSize="12"
                                                   FontAttributes="Bold"
                                                   TextColor="{StaticResource White}" />
                                        </HorizontalStackLayout>
                                    </Border>
                                </VerticalStackLayout>
                            </Grid>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
        <HorizontalStackLayout 
            VerticalOptions="End" 
            Margin="28,0,0,0" 
            Grid.Row="2">
            <Label Text="Total:"
                   FontSize="12"
                   FontAttributes="Bold"
                   TextColor="{StaticResource Gray900}"/>

            <Label Text="89"
                   Margin="4,0,0,0"
                   FontSize="12"
                   FontAttributes="Bold"
                   TextColor="{StaticResource Gray500}"/>
        </HorizontalStackLayout>
        <controls:ActivityIndicatorView IsVisible="{Binding IsBusy}" />
    </Grid>
</views:BaseContentPage>