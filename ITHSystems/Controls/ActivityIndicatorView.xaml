<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:resources="clr-namespace:ITHSystems.Resx"
              xmlns:icon="clr-namespace:ITHSystems.UsesCases.IconFonts"
             x:Class="ITHSystems.Controls.ActivityIndicatorView">
    <Grid
 HorizontalOptions="Fill"
 InputTransparent="False"
 VerticalOptions="Fill"
     BackgroundColor="#80000000"
     ZIndex="100"
     >

        <BoxView
     BackgroundColor="Transparent"
     VerticalOptions="Fill"
            
     HorizontalOptions="Fill"
     InputTransparent="False"/>
        <Frame
 BackgroundColor="Transparent"
 BorderColor="Transparent"
 CornerRadius="0"
 HorizontalOptions="Fill"
 InputTransparent="False"
            Margin="0"
            
 IsClippedToBounds="True"
 VerticalOptions="Fill" />
        <!--  Contenedor sin opacidad  -->
        <Border
     BackgroundColor="White"
     HeightRequest="90"
             InputTransparent="False"
     HorizontalOptions="Center"
     Stroke="{StaticResource White}"
     StrokeShape="RoundRectangle 20"
     VerticalOptions="Center"
                   Margin="0"
            
     WidthRequest="130">
            <Grid
         HorizontalOptions="Center"
         RowDefinitions="Auto,Auto,Auto"
                       Margin="0"
            
                 InputTransparent="False"
         VerticalOptions="Center">
                <ActivityIndicator
             Grid.Row="0"
             HeightRequest="40"
             IsRunning="True"
             WidthRequest="40"
                            Margin="0"
            
             ZIndex="1"
                    
             Color="{StaticResource Primary}" />
                <Border Grid.Row="0"
                        HeightRequest="50"
                        Margin="-4,-3,0,0"
                        Stroke="Transparent"
                        WidthRequest="80"
                        >
                    <Image
                     Aspect="Fill"
                     HeightRequest="90"
                     HorizontalOptions="Center"
                     Source="logo_ibs.png"
                     VerticalOptions="Center"
                     WidthRequest="90" />

                </Border>

                <Label
                     Grid.Row="2"
                     FontSize="Caption"
                     HorizontalOptions="Center"
                    FontFamily="{Static icon:FontFamilyIcons.FluentUI}"
                    FontAttributes="Bold"
                    TextColor="{StaticResource Gray900}"
                     Text="{Static resources:IBSResources.Loading}"
                     VerticalOptions="End" />

            </Grid>
        </Border>
    </Grid>
</ContentView>
