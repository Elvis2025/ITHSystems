<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ITHSystems.Controls.BarcodeScannerView"
              xmlns:zxing="clr-namespace:ZXing.Net.Maui.Controls;assembly=ZXing.Net.Maui.Controls"
             
             x:Name="This"
             >
    <Grid RowDefinitions="*,Auto">

        <Border Stroke="#D9D9D9"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 16"
                BackgroundColor="Black"
                HeightRequest="260">

            <Grid>
                <zxing:CameraBarcodeReaderView x:Name="BarcodeReader"
                                               BarcodesDetected="OnBarcodesDetected" />

                <Grid InputTransparent="True"
                      RowDefinitions="*,Auto,*"
                      ColumnDefinitions="*,Auto,*">

                    <BoxView Grid.RowSpan="3"
                             Grid.ColumnSpan="3"
                             Color="#000000"
                             Opacity="0.15" />

                    <Border Grid.Row="1"
                            Grid.Column="1"
                            Stroke="#35C9C2"
                            StrokeThickness="2"
                            StrokeShape="RoundRectangle 14"
                            BackgroundColor="Transparent"
                            WidthRequest="230"
                            HeightRequest="110" />

                    <Label Grid.Row="2"
                           Grid.Column="1"
                           Margin="0,14,0,0"
                           Text="Coloque el código dentro del recuadro"
                           HorizontalTextAlignment="Center"
                           TextColor="White"
                           FontSize="14" />
                </Grid>
            </Grid>
        </Border>

        <HorizontalStackLayout Grid.Row="1"
                               Margin="0,12,0,0"
                               HorizontalOptions="Center"
                               Spacing="12">

            <Button Text="Iniciar"
                    Command="{Binding Source={x:Reference This}, Path=StartScanningCommand}"
                    BackgroundColor="#35C9C2"
                    TextColor="White"
                    CornerRadius="12"
                    HeightRequest="42" />

            <Button Text="Detener"
                    Command="{Binding Source={x:Reference This}, Path=StopScanningCommand}"
                    BackgroundColor="#F3F4F6"
                    TextColor="#111827"
                    CornerRadius="12"
                    HeightRequest="42" />
        </HorizontalStackLayout>
    </Grid>
</ContentView>
