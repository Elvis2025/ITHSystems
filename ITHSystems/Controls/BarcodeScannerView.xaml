<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ITHSystems.Controls.BarcodeScannerView"
              xmlns:zxing="clr-namespace:ZXing.Net.Maui.Controls;assembly=ZXing.Net.Maui.Controls"
              xmlns:zx="clr-namespace:ZXing.Net.Maui;assembly=ZXing.Net.MAUI"
             x:Name="This"
             >
    <Border Stroke="#D9D9D9"
        StrokeThickness="0"
        BackgroundColor="Transparent"
        HeightRequest="240">

        <Grid>
            <zxing:CameraBarcodeReaderView x:Name="BarcodeReader"
                                       BarcodesDetected="OnBarcodesDetected"
                                        IsDetecting="False"
                                         CameraLocation="Rear"
                                         HorizontalOptions="Fill"
                                         VerticalOptions="Fill"
                                       >

                <zxing:CameraBarcodeReaderView.Options>
                    <zx:BarcodeReaderOptions
                        Formats="Pdf417,Code39,Code128,Ean13,UpcA,QrCode"
                        AutoRotate="True"
                        TryHarder="True"
                        Multiple="False" />
                </zxing:CameraBarcodeReaderView.Options>

            </zxing:CameraBarcodeReaderView>

           
        </Grid>
    </Border>
</ContentView>
